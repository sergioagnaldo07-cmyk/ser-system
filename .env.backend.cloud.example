# =============================
# SER System - Backend (Render/Railway/Fly)
# Copie este conteúdo para as variáveis do serviço backend.
# =============================

# Obrigatório
OPENAI_API_KEY=cole_sua_chave_openai

# Modelos (mais econômicos para manter custo baixo)
OPENAI_MODEL_CHAT=gpt-4o-mini
OPENAI_MODEL_PARSER=gpt-4o-mini
OPENAI_MODEL_WHATSAPP=gpt-4o-mini
OPENAI_MODEL_TRANSCRIBE=gpt-4o-mini-transcribe

# Limites de tokens (controlam custo)
OPENAI_MAX_TOKENS_CHAT=700
OPENAI_MAX_TOKENS_PARSER=650
OPENAI_MAX_TOKENS_WHATSAPP=420
WHATSAPP_CONTEXT_TASK_LIMIT=10
APP_CHAT_HISTORY_LIMIT=5
APP_CHAT_MAX_CHARS_PER_MESSAGE=650
OPENAI_CACHE_TTL_MS=300000
OPENAI_CACHE_MAX_ITEMS=600
WHATSAPP_LLM_HISTORY_TURNS=1
WHATSAPP_LLM_HISTORY_TTL_MS=900000

# Rede e segurança
NODE_ENV=production
PORT=3101
CORS_ORIGIN=https://SEU_FRONTEND_AQUI
SER_ADMIN_TOKEN=defina_um_token_forte
SER_REQUIRE_AUTH_FOR_READ=false

# Storage (modo híbrido recomendado)
SER_STORAGE_MODE=auto
SER_DATA_DIR=/app/persist/data

# Supabase (opcional, recomendado)
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=cole_service_role_key
SUPABASE_TASKS_TABLE=ser_tasks
SUPABASE_USAGE_TABLE=ser_usage_events
SUPABASE_USAGE_MAX_ROWS=12000

# WhatsApp
WHATSAPP_AUTH_PATH=/app/persist/whatsapp_auth
WHATSAPP_NUMBER=
WHATSAPP_RESTRICT_NUMBER=false
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
WHATSAPP_AUTO_RECONNECT=true
WHATSAPP_RECONNECT_BASE_MS=5000
WHATSAPP_RECONNECT_MAX_MS=60000

# Lembretes
WHATSAPP_TASK_REMINDER_MINUTES=60
WHATSAPP_REMINDER_AT_TIME_ENABLED=true
WHATSAPP_DAILY_FOLLOWUP_DEFAULT_TIME=10:00
WHATSAPP_END_REPORT_HOUR=20
WHATSAPP_END_REPORT_MINUTE=0
WHATSAPP_WEEKLY_COST_REPORT_ENABLED=true
WHATSAPP_WEEKLY_COST_REPORT_DAY=1
WHATSAPP_WEEKLY_COST_REPORT_HOUR=9
WHATSAPP_WEEKLY_COST_REPORT_MINUTE=0

# Áudio no WhatsApp
WHATSAPP_AUDIO_REQUIRE_CONFIRM=false
WHATSAPP_AUDIO_CONFIRM_TTL_MINUTES=20
WHATSAPP_AUDIO_MAX_MB=25
OPENAI_TRANSCRIBE_RESPONSE_FORMAT=json

# Cálculo de custo (valores de referência)
OPENAI_PRICE_GPT4O_MINI_INPUT_PER_1M=0.15
OPENAI_PRICE_GPT4O_MINI_OUTPUT_PER_1M=0.60
OPENAI_PRICE_DEFAULT_INPUT_PER_1M=0.15
OPENAI_PRICE_DEFAULT_OUTPUT_PER_1M=0.60
OPENAI_PRICE_TRANSCRIBE_PER_MIN=0.003
